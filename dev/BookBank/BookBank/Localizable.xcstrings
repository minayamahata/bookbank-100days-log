    "account.delete.message_empty" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete \"%@\"?\n\nThis action cannot be undone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」を削除してもよろしいですか？\n\nこの操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」을(를) 삭제하시겠습니까?\n\n이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定要删除「%@」吗？\n\n此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確定要刪除「%@」嗎？\n\n此操作無法復原。"
          }
        }
      }
    },
    "account.delete.message_with_books" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deleting \"%1$@\" will also delete %2$lld books registered in this account.\n\nThis action cannot be undone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%1$@」を削除すると、この口座に登録されている%2$lld冊の本も削除されます。\n\nこの操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%1$@」을(를) 삭제하면 이 계좌에 등록된 %2$lld권의 책도 삭제됩니다.\n\n이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除「%1$@」也会删除此账户中登记的 %2$lld 本书。\n\n此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "刪除「%1$@」也會刪除此帳戶中登錄的 %2$lld 本書。\n\n此操作無法復原。"
          }
        }
      }
    },
